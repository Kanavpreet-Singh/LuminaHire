// LuminaHire - Agentic HR Tech Platform
// Database: PostgreSQL (NeonDB)

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  hashedPassword String?
  image          String?
  emailVerified  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  role      UserRole @default(CANDIDATE)
  candidate Candidate?

  companyName String? // Used if role is RECRUITER
  jobPostings JobPosting[] // Used if role is RECRUITER

  accounts    Account[]

  @@map("users")
}

enum UserRole {
  RECRUITER
  CANDIDATE
}

// ----------------------------------------------------------------------
// NEW LUMINAHIRE MODELS
// ----------------------------------------------------------------------

model JobPosting {
  id           String     @id @default(cuid())
  title        String
  description  String     @db.Text
  requirements String?    @db.Text
  status       JobStatus  @default(OPEN)
  
  recruiterId  String
  recruiter    User       @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  
  // Vector embedding for semantic matching (1536 dimensions in database).
  embedding    Unsupported("vector(1536)")?
  
  applications Application[]
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  @@map("job_postings")
}

enum JobStatus {
  OPEN
  PAUSED
  CLOSED
}

model Candidate {
  id          String   @id @default(cuid())
  
  userId      String?  @unique
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  email       String   @unique
  phone       String?
  
  resumeUrl   String?  @db.Text
  resumeText  String?  @db.Text
  skills      String[]
  
  linkedinUrl String?  @db.Text
  githubUrl   String?  @db.Text
  
  // Vector embedding for semantic search (1536 dimensions in database).
  embedding   Unsupported("vector(1536)")? 
  
  applications Application[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("candidates")
}

model Application {
  id          String   @id @default(cuid())
  
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  
  jobId       String
  job         JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  status      AppStatus @default(PENDING)
  
  matchScore  Float?
  aiSummary   String?    @db.Text
  aiPros      String[]
  aiCons      String[]
  
  vettingSession VettingSession?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([candidateId, jobId])
  @@map("applications")
}

model VettingSession {
  id            String   @id @default(cuid())
  applicationId String   @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  
  status        VettingSessionStatus @default(PLANNING)

  // HITL sessions pause at AWAITING_RESEARCH_INPUT/AWAITING_EVALUATION_APPROVAL;
  // AUTONOMOUS sessions (batch "Hiring Committee" runs) skip both checkpoints.
  // Crash-recovery (resume) reads this so a restarted HITL run still pauses
  // for review instead of silently completing.
  pipelineMode  VettingPipelineMode @default(HITL)

  // Store the research plan (JSON)
  researchPlan  Json?

  // Store the gathered research results (JSON)
  researchResults Json?

  // Store the evaluator's raw findings (dimension scores, evidence, gaps)
  // pending human approval before the report writer runs.
  evaluation    Json?

  // Store the final consolidated report / details (JSON)
  finalReport   Json?

  // Q&A history over the accumulated research context (list of {question, answer, askedAt})
  qaHistory     Json?

  // Logs of the agent session (JSON array of strings)
  logs          Json?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("vetting_sessions")
}

enum VettingSessionStatus {
  PLANNING
  RESEARCHING
  AWAITING_RESEARCH_INPUT
  EVALUATING
  AWAITING_EVALUATION_APPROVAL
  COMPLETED
  FAILED
}

enum VettingPipelineMode {
  HITL
  AUTONOMOUS
}

enum AppStatus {
  PENDING
  AI_PROCESSING
  AI_SHORTLISTED
  AI_REJECTED
  HUMAN_APPROVED
  INTERVIEWING
  OFFERED
  REJECTED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}
